{
  "shard_id": "zone_s_log_metabolism_alt",
  "domain": "log_metabolism_alt",
  "routing_keywords": [
    "timestamp",
    "trace_id",
    "egress",
    "throttle",
    "latency_ms",
    "json",
    "error",
    "warn",
    "span_id",
    "request_id"
  ],
  "must_keep_hard_terms": [
    "timestamp",
    "trace_id",
    "egress",
    "throttle",
    "status_code",
    "level"
  ],
  "must_keep_soft_terms": [
    "request_id",
    "span_id",
    "latency_ms",
    "json",
    "method",
    "path",
    "http",
    "grpc",
    "message",
    "pod",
    "container"
  ],
  "guard_tokens": [
    "error",
    "fatal",
    "timeout",
    "auth"
  ],
  "hangul_principle": false
}
